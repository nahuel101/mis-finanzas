# Copiá este archivo a .env.local y completá los valores.

# Se completa solo si usás la integración de Neon desde Vercel (Storage →
# Create Database). Para probar en tu compu, copiá el valor desde
# Vercel → tu proyecto → Storage → tu base → pestaña ".env.local".
DATABASE_URL=postgresql://usuario:password@host/dbname?sslmode=require

# Secreto para cifrar las sesiones de Auth.js. Podés usar este valor para
# arrancar, pero para producción es mejor generar uno propio (cualquier
# cadena aleatoria larga sirve, por ejemplo con un generador de
# contraseñas). Tiene que ser el mismo tanto en local como en Vercel.
AUTH_SECRET=TY2kHXDi9s4tM1iPU8XzwFE4H7zl+i8yOzd+M2G21zF2
